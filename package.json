{
  "name": "@govuk-one-login/data-npm",
  "version": "0.0.1",
  "description": "Standardised logger for GOV.UK One Login data pod Lambda functions",
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": "./dist/index.js",
  "private": false,
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/govuk-one-login/data-npm"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build --workspaces && changeset publish"
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.25.2",
    "@aws-lambda-powertools/metrics": "^2.25.2",
    "@aws-lambda-powertools/tracer": "^2.25.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.126",
    "@vitest/coverage-v8": "^3.0.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "vitest": "^3.0.0",
    "@changesets/cli": "^2.27.0"
  }
}
