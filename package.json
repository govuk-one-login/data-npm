{
  "name": "@govuk-one-login/data-npm",
  "version": "0.0.5",
  "description": "Standardised logger for GOV.UK One Login data pod Lambda functions",
  "type": "module",
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": "./dist/index.js",
  "private": false,
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@govuk-one-login:registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/govuk-one-login/data-npm"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --coverage",
    "lint": "oxlint --config oxlint.config.ts",
    "lint:fix": "oxlint --config oxlint.config.ts --fix",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,js}": [
      "oxlint --config oxlint.config.ts --fix",
      "oxlint --config oxlint.config.ts"
    ]
  },
  "dependencies": {
    "@aws-lambda-powertools/logger": "^2.25.2",
    "@aws-lambda-powertools/metrics": "^2.25.2",
    "@aws-lambda-powertools/tracer": "^2.25.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@tsconfig/node-ts": "^23.6.4",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/aws-lambda": "^8.10.126",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vitest": "^3.0.0"
  }
}
